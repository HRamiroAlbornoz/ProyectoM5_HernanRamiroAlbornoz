{
  "name": "automatehub-mcp-server",
  "version": "1.0.0",
  "description": "MCP Server para automatizar operaciones de GitHub mediante lenguaje natural",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/server.ts",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "mcp",
    "github",
    "ai-agents",
    "automatehub"
